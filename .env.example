NODE_ENV=development

# Public web and edge
WEB_PORT=3000
ADMIN_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_ADMIN_API_BASE_URL=http://localhost:4000/api/v1
HTTP_PORT=80
HTTPS_PORT=443
WEB_DOMAIN=localhost
API_DOMAIN=api.localhost
ADMIN_DOMAIN=admin.localhost
ACME_EMAIL=

# API
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_SWAGGER_ENABLED=true
API_AUTH_SECRET=change_me_to_a_long_random_secret
API_ACCESS_TOKEN_TTL_SECONDS=3600
API_LOGIN_RATE_LIMIT_MAX=5
API_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
API_PROMOTION_TOKEN_TTL_SECONDS=1800
API_PROMOTION_RATE_LIMIT_MAX=20
API_PROMOTION_RATE_LIMIT_WINDOW_SECONDS=900
API_DEFAULT_SHIPPING_FEE_VND=0
API_ORDER_INTEGRATIONS=sheet

# Cloudinary image upload
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_PRODUCT_IMAGE_FOLDER=ecommerce-products

# Integration worker
API_INTEGRATION_TIMEOUT_SECONDS=10
API_INTEGRATION_MAX_ATTEMPTS=5
API_INTEGRATION_BACKOFF_BASE_SECONDS=60
API_INTEGRATION_POLL_INTERVAL_SECONDS=5
API_INTEGRATION_BATCH_SIZE=10
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/run/secrets/google-service-account.json
# Alternative for non-Docker runtime. Keep this as a single-line JSON string and never commit real values.
# GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_CACHE_TTL_SECONDS=60
# Partner HTTP adapters are disabled unless both BASE_URL and CREATE_ORDER_PATH are configured.
# Use mock/sandbox endpoints only until real API docs and credentials are confirmed.
# API_INTEGRATION_SHEET_BASE_URL=
# API_INTEGRATION_SHEET_CREATE_ORDER_PATH=
# API_INTEGRATION_SHEET_UPDATE_ORDER_PATH=
# API_INTEGRATION_SHEET_GET_ORDER_STATUS_PATH=
# API_INTEGRATION_SHEET_HEALTH_CHECK_PATH=
# API_INTEGRATION_SHEET_TOKEN=
# API_INTEGRATION_PANCAKE_BASE_URL=
# API_INTEGRATION_PANCAKE_CREATE_ORDER_PATH=
# API_INTEGRATION_PANCAKE_UPDATE_ORDER_PATH=
# API_INTEGRATION_PANCAKE_GET_ORDER_STATUS_PATH=
# API_INTEGRATION_PANCAKE_HEALTH_CHECK_PATH=
# API_INTEGRATION_PANCAKE_TOKEN=
# API_INTEGRATION_BEST_BASE_URL=
# API_INTEGRATION_BEST_CREATE_ORDER_PATH=
# API_INTEGRATION_BEST_UPDATE_ORDER_PATH=
# API_INTEGRATION_BEST_GET_ORDER_STATUS_PATH=
# API_INTEGRATION_BEST_HEALTH_CHECK_PATH=
# API_INTEGRATION_BEST_TOKEN=
DEV_ADMIN_PASSWORD=replace_with_local_dev_password

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://ecommerce:change_me@localhost:5432/ecommerce?schema=public

# Backup and operations
BACKUP_RETENTION_DAYS=14
BACKUP_TARGET=local-volume
ALERT_ERROR_RATE_THRESHOLD_PERCENT=5
ALERT_INTEGRATION_FAILED_THRESHOLD=1
ALERT_INTEGRATION_PENDING_MAX_AGE_MINUTES=15
